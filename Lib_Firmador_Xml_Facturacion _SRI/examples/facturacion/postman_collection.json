{
  "info": {
    "_postman_id": "6af152d8-3d74-4694-83ef-4f5d64fbe021",
    "name": "Facturacion SRI - flujo completo factura",
    "description": "Coleccion para validar el flujo completo de facturacion de este proyecto: validar datos, generar XML, firmar, enviar al SRI y consultar autorizacion.",
