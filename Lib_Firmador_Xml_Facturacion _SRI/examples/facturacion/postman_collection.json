    {
      "name": "03 - Generar XML factura",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tipo\": \"factura\",\n  \"data\": {\n    \"infoTributaria\": {\n      \"ambiente\": \"{{ambiente}}\",\n      \"tipoEmision\": \"1\",\n      \"razonSocial\": \"EMPRESA DEMO S.A.\",\n      \"nombreComercial\": \"EMPRESA DEMO\",\n      \"ruc\": \"1790012345001\",\n      \"codigoNumerico\": \"12345678\",\n      \"codDoc\": \"01\",\n      \"estab\": \"001\",\n      \"ptoEmi\": \"001\",\n      \"secuencial\": \"000000001\",\n      \"dirMatriz\": \"Quito\",\n      \"regimen\": \"0\"\n    },\n    \"infoFactura\": {\n      \"fechaEmision\": \"2026-06-01\",\n      \"dirEstablecimiento\": \"Quito\",\n      \"obligadoContabilidad\": \"NO\",\n      \"tipoIdentificacionComprador\": \"05\",\n      \"razonSocialComprador\": \"CLIENTE DEMO\",\n      \"identificacionComprador\": \"1710034065\",\n      \"totalSinImpuestos\": \"100.00\",\n      \"totalDescuento\": \"0.00\",\n      \"totalImpuesto\": [\n        {\n          \"codigo\": \"2\",\n          \"codigoPorcentaje\": \"4\",\n          \"baseImponible\": \"100.00\",\n          \"valor\": \"15.00\"\n        }\n      ],\n      \"propina\": \"0.00\",\n      \"importeTotal\": \"115.00\",\n      \"moneda\": \"DOLAR\",\n      \"pagos\": {\n        \"formaPago\": \"01\",\n        \"total\": \"115.00\"\n      }\n    },\n    \"detalle\": [\n      {\n        \"codigoPrincipal\": \"SERV-001\",\n        \"codigoAuxiliar\": \"SERV-001\",\n        \"descripcion\": \"Servicio demo\",\n        \"cantidad\": \"1.00\",\n        \"precioUnitario\": \"100.00\",\n        \"descuento\": \"0.00\",\n        \"precioTotalSinImpuesto\": \"100.00\",\n        \"impuesto\": {\n          \"codigo\": \"2\",\n          \"codigoPorcentaje\": \"4\",\n          \"tarifa\": \"15\",\n          \"baseImponible\": \"100.00\",\n          \"valor\": \"15.00\"\n        }\n      }\n    ],\n    \"infoAdicional\": {\n      \"telefono\": \"0999999999\",\n      \"email\": \"cliente@example.com\"\n    }\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/facturacion/xml",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "facturacion",
            "xml"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('XML generado', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(json.status).to.eql(true);",
              "  pm.expect(json.data.xml).to.include('<factura');",
              "  pm.expect(json.data.xml_base64).to.not.be.empty;",
              "});",
              "pm.environment.set('xml_base64', json.data.xml_base64);",
              "const match = json.data.xml.match(/<claveAcceso>(.*?)<\\/claveAcceso>/);",
              "if (match) {",
              "  pm.environment.set('clave_acceso', match[1]);",
              "}"
            ]
          }
        }
      ]
    },
