    {
      "name": "02 - Generar clave de acceso factura",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Accept",
            "value": "application/json"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fecha_emision\": \"2026-06-01\",\n  \"tipo_comprobante\": \"01\",\n  \"ruc\": \"1790012345001\",\n  \"ambiente\": \"{{ambiente}}\",\n  \"serie\": \"001001\",\n  \"secuencial\": \"000000001\",\n  \"codigo_numerico\": \"12345678\",\n  \"tipo_emision\": \"1\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/facturacion/clave-acceso",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "facturacion",
            "clave-acceso"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const json = pm.response.json();",
              "pm.test('Clave generada', function () {",
              "  pm.response.to.have.status(200);",
              "  pm.expect(json.data.clave_acceso).to.have.length(49);",
              "});",
              "pm.environment.set('clave_acceso', json.data.clave_acceso);"
            ]
          }
        }
      ]
